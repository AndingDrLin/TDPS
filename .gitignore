# Python
.venv/
__pycache__/
*.pyc
*.egg-info/

# Node / web tooling
node_modules/
.wrangler/

# macOS
.DS_Store

# IDE / editor metadata
.vscode/
.idea/
.settings/
*.launch

# CMake / local build outputs
build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Firmware and simulator generated outputs
TDPS/firmware/build/
TDPS/simulator/artifacts/**
!TDPS/simulator/artifacts/
!TDPS/simulator/artifacts/README.md

# Root-level pipeline artifacts (project-specific artifacts use rules above)
artifacts/**
!artifacts/
!artifacts/README.md

# Keil MDK / embedded build artifacts
*.lst
*.htm
*.crf
*.d
*.o
*.elf
*.axf
*.bin
*.hex
*.map
*.lnp
*.dep
*.build_log.htm
Debug/
Release/
Objects/
Listings/
DebugConfig/
RTE/
JLinkLog.txt
JLinkSettings.ini
EventRecorderStub.scvd
*.uvguix.*
*.uvoptx
*.uvopt
*.uvprojx
!TDPS/firmware/**/*.uvprojx
!TDPS/tests/standalone/**/*.uvprojx

# STM32CubeMX / Eclipse metadata outside the main firmware project
*.ioc
*.mxproject
.project
.cproject
!TDPS/firmware/**/*.ioc
!TDPS/firmware/**/.mxproject

# Claude Code local state and guidance (not for version control)
.claude/
CLAUDE.md

# Local reference packages are indexed by README only
docs_reference/**
!docs_reference/
!docs_reference/README.md

# Binary / non-code reference assets (except reports/, which is fully tracked)
*.pdf
*.docx
*.pptx
*.xlsx
*.zip
*.rar
*.7z
*.epro2
*.PcbDoc
*.SchDoc
*.dwg
*.exe
*.png
*.jpg
*.jpeg
*.bmp
*.gif
# Re-include reports/ before the common ignore rules above take effect
!reports/**
# ... but still ignore junk files inside reports/
reports/**/.DS_Store
reports/**/__pycache__/
reports/**/.venv/

# Local archives or legacy ignored directories kept outside TDPS
slides/
.claude/settings.local.json
